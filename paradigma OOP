#include <iostream>
using namespace std;


class barang{
    public:
       string nama;
       int jumlah;
       string kategori;git
       string tanggal_produksi;

       void printData(){
            cout << "nama : " << nama << endl;
            cout << "jumlah : " << jumlah << endl;
            cout << "kategori : " << kategori << endl;
            cout << "tanggal_produksi : " << tanggal_produksi << endl;
       }
};

int main(){
    barang elektronik;
    barang nonElektronik;

    elektronik.nama = "laptop";
    elektronik.jumlah = 20;
    elektronik.kategori = "High end";
    elektronik.tanggal_produksi = "20 agustus 2022";


    nonElektronik.nama = "buku";
    nonElektronik.jumlah = 200;
    nonElektronik.kategori = "filsafat";
    nonElektronik.tanggal_produksi = "20 juli 2022";

    elektronik.printData();
    nonElektronik.printData();

}


   